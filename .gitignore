# .gitignore generated for GetItDone project
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
# Uncomment if you have a virtualenv directory
env/
venv/
ENV/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# PyInstaller
#  Usually these files are written by a script from a template
#  before PyInstaller builds the exe, so as to inject a version
#  number into the generated executable.
*.manifest
*.spec

# Installer logs
*.log

# macOS folder attributes
.DS_Store

# Windows thumbnail cache files
Thumbs.db

# IDEs and editors
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# PyCharm
*.iml

# Jupyter Notebook
.ipynb_checkpoints

# Local environment files
.env